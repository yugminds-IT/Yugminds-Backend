# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/yugminds

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# Strong random secrets — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Token lifetimes — format: <number><s|m|h|d> (e.g. 15m, 7d)
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ─── Security ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000

# Secret for internal service-to-service requests
INTERNAL_API_KEY=change_me_internal_api_key

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Maximum JSON body size (optional — defaults to 1mb)
# JSON_BODY_LIMIT=1mb

# ─── Feature flags ───────────────────────────────────────────────────────────
# Set to "true" to enable assignment retake feature
# ASSIGNMENT_RETAKE_FEATURE_ENABLED=true
