{
  "info": {
    "name": "Yugminds API",
    "description": "Role-based auth API (admin, school_admin, teacher, student)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup - Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@yugminds.com\",\n  \"password\": \"Admin1234\",\n  \"role\": \"admin\",\n  \"isSuperAdmin\": true\n}"
            },
            "url": "{{baseUrl}}/auth/signup",
            "description": "Create admin (super admin) account"
          }
        },
        {
          "name": "Signup - School Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"schooladmin@yugminds.com\",\n  \"password\": \"SchoolAdmin123\",\n  \"role\": \"school_admin\",\n  \"tenantId\": \"<school-uuid>\"\n}"
            },
            "url": "{{baseUrl}}/auth/signup",
            "description": "Create school admin account (requires tenantId/school)"
          }
        },
        {
          "name": "Signup - Teacher",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@yugminds.com\",\n  \"password\": \"Teacher123\",\n  \"role\": \"teacher\",\n  \"tenantId\": \"<school-uuid>\"\n}"
            },
            "url": "{{baseUrl}}/auth/signup",
            "description": "Create teacher account"
          }
        },
        {
          "name": "Signup - Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@yugminds.com\",\n  \"password\": \"Student123\",\n  \"role\": \"student\",\n  \"tenantId\": \"<school-uuid>\"\n}"
            },
            "url": "{{baseUrl}}/auth/signup",
            "description": "Create student account"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.tokens) {",
                  "    pm.collectionVariables.set('accessToken', json.tokens.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.tokens.refreshToken);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@yugminds.com\",\n  \"password\": \"Admin1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Login with email and password. Saves accessToken and refreshToken to collection variables."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.tokens) {",
                  "    pm.collectionVariables.set('accessToken', json.tokens.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.tokens.refreshToken);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Get new access token using refresh token"
          }
        }
      ]
    }
  ]
}
